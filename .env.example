# comfy-bridge .env — copy to `.env` and fill in. `.env` is gitignored: NEVER commit keys.
# Mirrors a working setup with all secret values (keys) + private gateway URLs stripped.
#
# Two proven deployment styles (pick one per provider):
#   A) Single multi-protocol gateway (e.g. 网易雷火 / one-api / new-api): point every
#      provider at the SAME base URL + key; leave BYTEPLUS_BACKEND unset (native Ark).
#   B) litellm gateway + fal-ai: per-provider base URLs with path quirks (see notes below),
#      and route ByteDance to fal.ai via BYTEPLUS_BACKEND=fal-ai + FAL_KEY.

BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8190
# BRIDGE_ASSET_DIR defaults to <bridge_dir>/asset-cache when unset (works on Linux + Windows)
# BRIDGE_ASSET_DIR=
BRIDGE_GATING=on
BRIDGE_CORS_ORIGINS=http://127.0.0.1:8188,http://localhost:8188
# Log every upstream call's input/output body to the bridge log (truncated, base64
# collapsed, headers/keys excluded). Set to off to silence. Default on.
# BRIDGE_LOG_IO=on

# Upstream HTTP read timeout in seconds (default 300). Raise if a synchronous model
# (e.g. gpt-image-2) takes longer than this to return.
# BRIDGE_HTTP_TIMEOUT=300
# Comma-separated hosts merged into NO_PROXY so gateway-bound requests bypass a system
# HTTP(S) proxy/VPN (e.g. v2rayN at 127.0.0.1:10808) that would otherwise kill the long
# synchronous connection (gpt-image-2 etc.) -> ReadTimeout. Uncomment if you run a proxy.
# BRIDGE_NO_PROXY=ai.leihuo.netease.com

# ── Gating allowlist (comma-separated; NOT secret — kept in the example) ──
# NB: the ByteDance/Seedance gating vendor name is "bytedance" (derived from python_module
# nodes_bytedance), NOT the byteplus/byteplus-seedance2 route segments.
BRIDGE_ALLOWED_VENDORS=openai,anthropic,gemini,tripo,bytedance
# Hard-hide classes from the menu (denylist; wins over vendor allow) — for nodes an allowed
# vendor's gateway can't serve at all. Below hides DALL·E (leihuo has only gpt-image) +
# the deprecated Seedance 1.x video nodes.
BRIDGE_HIDDEN_NODE_CLASSES=OpenAIDalle2,OpenAIDalle3,ByteDanceTextToVideoNode,ByteDanceImageToVideoNode,ByteDanceFirstLastFrameNode,ByteDanceImageReferenceNode
# Optional explicit class allowlist (else falls back to code baseline DEFAULT_ALLOWED_*):
# BRIDGE_ALLOWED_NODE_CLASSES=ClaudeNode,OpenAIChatNode,...,ByteDance2TextToVideoNode

# ── Providers — fill in base URL + key (keys NEVER committed) ──
# Per-provider path quirks (matter for litellm-style gateways; a single gateway like leihuo
# usually takes the bare origin for all):
#   OpenAI    base = origin root, OR end with /v1 (bridge dedups a trailing /v1)
#   Anthropic base must NOT include /v1 (adapter posts native /v1/messages itself;
#             unlike OpenAI there is NO auto-dedup, so a stray /v1 silently 404s)
#   Gemini    on a litellm gateway use the Google AI-Studio passthrough: <gateway>/gemini
#             (bridge strips the Vertex-only default imageOutputOptions so image nodes
#              don't 400 against AI Studio)
OPENAI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
GEMINI_BASE_URL=
GEMINI_API_KEY=
TRIPO_BASE_URL=
TRIPO_API_KEY=
# ByteDance/Seedance native (Ark) gateway — shared by the byteplus/byteplus-seedance2/seedance segments.
BYTEPLUS_BASE_URL=
BYTEPLUS_API_KEY=

# ── Backend selection (default 'native' if unset) ────────────────────────────
# Each vendor can have multiple backend implementations. Set {VENDOR}_BACKEND to switch.
# OPENAI_BACKEND=native
# ANTHROPIC_BACKEND=native
# GEMINI_BACKEND=native
# TRIPO_BACKEND=native
# BYTEPLUS_BACKEND=native

# ── fal-ai backend for ByteDance (alternative to the native Ark gateway) ──
# Routes the byteplus vendor's nodes to fal.ai (queue.fal.run). Supports a SUBSET:
#   video: Seedance 2.0 only  (ByteDance2TextToVideoNode / 2FirstLastFrameNode / 2ReferenceNode)
#   image: Seedream v4 / v4.5 / v5-lite  (ByteDanceSeedreamNode / ByteDanceSeedreamNodeV2)
#   NOT supported: Seedance 1.x, seedream-3-0 (ByteDanceImageNode), and the asset-management
#   nodes CreateImageAsset / CreateVideoAsset (return a clear 424).
# BYTEPLUS_BACKEND=fal-ai
# FAL_KEY=
