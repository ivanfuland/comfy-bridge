BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8190
# BRIDGE_ASSET_DIR defaults to <bridge_dir>/asset-cache when unset (works on Linux + Windows)
# BRIDGE_ASSET_DIR=
BRIDGE_GATING=on
BRIDGE_CORS_ORIGINS=http://127.0.0.1:8188,http://localhost:8188
# Log every upstream call's input/output body to the bridge log (truncated, base64
# collapsed, headers/keys excluded). Set to off to silence. Default on.
# BRIDGE_LOG_IO=on

# Upstream HTTP read timeout in seconds (default 300). Raise if a synchronous model
# (e.g. gpt-image-2) takes longer than this to return.
# BRIDGE_HTTP_TIMEOUT=300
# Comma-separated hosts merged into NO_PROXY so gateway-bound requests bypass a system
# HTTP(S) proxy/VPN (e.g. v2rayN) that would otherwise kill the long connection.
# BRIDGE_NO_PROXY=ai.leihuo.netease.com

# Gating allowlist overrides (optional, comma-separated). Leave unset to use the
# code baseline in app/config.py (DEFAULT_ALLOWED_*). Set to fully replace a list —
# this keeps enabling/disabling nodes in config, not code (no git-pull conflicts).
# BRIDGE_ALLOWED_VENDORS=openai,anthropic,gemini,tripo,bytedance
# BRIDGE_ALLOWED_NODE_CLASSES=ClaudeNode,OpenAIChatNode,...,ByteDance2TextToVideoNode
# NB: ByteDance/Seedance gating vendor is "bytedance" (derived from python_module
# nodes_bytedance), NOT the byteplus/byteplus-seedance2 route segments.
# Hard-hide specific classes from the menu (denylist; wins over vendor allow) — use for
# nodes an allowed vendor's gateway can't serve at all (vs greying same-vendor unadapted).
# BRIDGE_HIDDEN_NODE_CLASSES=OpenAIDalle2,OpenAIDalle3

OPENAI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
GEMINI_BASE_URL=
GEMINI_API_KEY=
TRIPO_BASE_URL=
TRIPO_API_KEY=
# ByteDance/Seedance — shared by the byteplus/byteplus-seedance2/seedance segments.
BYTEPLUS_BASE_URL=
BYTEPLUS_API_KEY=

# ── Backend selection (default 'native' if unset) ────────────────────────────
# Each vendor can have multiple backend implementations. Set {VENDOR}_BACKEND
# to switch. Currently only 'native' is built; M2/M3 will add 'fal-ai' etc.
# OPENAI_BACKEND=native
# ANTHROPIC_BACKEND=native
# GEMINI_BACKEND=native
# TRIPO_BACKEND=native
# BYTEPLUS_BACKEND=native
